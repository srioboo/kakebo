# Justfile
# This file defines common tasks for the Kakebo backend project.

# Start the Spring Boot application
start:
    bash scripts/manage.sh start

# Stop the Spring Boot application
stop:
    bash scripts/manage.sh stop

# Run tests for the project
test:
    bash scripts/manage.sh test

# Build the project
build:
    bash scripts/manage.sh build

# Run all quality checks (SonarQube local + coverage)
lint:
    bash scripts/manage.sh lint

# Run SonarQube analysis (requires SonarQube server)
sonar:
    bash scripts/manage.sh sonar

# Run local SonarQube analysis (no server needed)
sonar-local:
    bash scripts/manage.sh sonar-local

# Generate code coverage reports
coverage:
    bash scripts/manage.sh coverage

# Display help
help:
    bash scripts/manage.sh help
